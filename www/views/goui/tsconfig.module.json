{
  "compilerOptions": {
    "strict": true,
    "target": "es2022",
    "sourceMap": true,
    "lib": [
      "es2022",
      "dom"
    ],
    "moduleResolution": "bundler",
    "module": "preserve",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "outDir": "./dist",
    //set this in the extended
    "baseUrl": ".",
    //set this in the extended too,
    "skipLibCheck": true,
    "declaration": true
  }
}
