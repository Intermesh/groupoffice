{
  "type": "module",
  "name": "maildomains",
  "devDependencies": {
    "concurrently": "latest",
    "esbuild": "latest",
    "sass": "latest",
    "typescript": "5.9.*"
  },
  "scripts": {
    "start maildomains": "npm run build:clean && concurrently --kill-others \"npm run start:ts\" \"npm run start:dts\"  \"npm run start:sass\"",
    "start:ts": "node ../../../../../../views/goui/esbuild-module.mjs watch",
    "start:dts": "npx tsc --declaration --emitDeclarationOnly --watch",
    "start:sass": "npx sass --watch style:dist",

    "build": "npm run build:clean && npm run build:sass && npm run build:ts",
    "build:clean": "rm -rf ./dist/*",
    "build:ts": "node ../../../../../../views/goui/esbuild-module.mjs",
    "build:sass": "npx sass --load-path=$(npm root) --style=compressed --no-source-map style:dist",
    "build:dts": "npx tsc -b --declaration --emitDeclarationOnly",

    "test": "npx tsc --noEmit"
  }
}