{
  "type": "module",
  "name": "@intermesh/community-addressbook",
  "main": "./dist/Index.js",
  "module": "./dist/Index.js",
  "typings": "./dist/Index.d.ts",
  "description": "GroupOffice Addressbook module",
  "devDependencies": {
    "concurrently": "latest",
    "esbuild": "latest",
    "sass": "latest",
    "typescript": "5.9.*"
  },
  "scripts": {
    "start addressbook": "concurrently --kill-others \"npm run start:ts\"  \"npm run start:dts\"",
    "start:ts": "node ../../../../../../views/goui/esbuild-module.mjs watch",
    "start:dts": "npx tsc -b --declaration --emitDeclarationOnly --watch",

    "build": "npm run build:ts",
    "build:clean": "rm -rf ./dist/*",
    "build:ts": "node ../../../../../../views/goui/esbuild-module.mjs",
    "build:dts": "npx tsc -b --declaration --emitDeclarationOnly",

    "test": "npx tsc --noEmit"
  }
}