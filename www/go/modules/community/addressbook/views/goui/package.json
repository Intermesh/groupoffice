{
  "type": "module",
  "name": "@intermesh/community-addressbook",
  "exports": {
    ".": {
      "types": "./script/Index.ts",
      "default": "./dist/Index.js"
    }
  },
  "description": "GroupOffice Addressbook module",
  "devDependencies": {
    "concurrently": "latest",
    "esbuild": "latest",
    "sass": "latest",
    "typescript": "5.9.*"
  },
  "scripts": {
    "start addressbook": "concurrently --kill-others \"npm run start:ts\"  \"npm run start:dts\" \"npm run start:sass\"",
    "start:ts": "node ../../../../../../views/goui/esbuild-module.mjs watch",
    "start:dts": "npx tsc -b --declaration --emitDeclarationOnly --watch",
    "start:sass": "npx sass --load-path=$(npm root) --watch style:dist",

    "build": "npm run build:ts",
    "build:clean": "rm -rf ./dist/*",
    "build:ts": "node ../../../../../../views/goui/esbuild-module.mjs",
    "build:sass": "npx sass --update --load-path=$(npm root) --style=compressed style:dist",
    "build:dts": "npx tsc -b --declaration --emitDeclarationOnly",

    "test": "npx tsc --noEmit",
    "prepare": "npm run build"
  }
}