{
  "type": "module",
  "name": "@intermesh/community-comments",
  "main": "./dist/Index.js",
  "module": "./dist/Index.js",
  "typings": "./dist/Index.d.ts",
  "description": "GroupOffice Comments module",
  "exports": {
    ".": "./dist/Index.js"
  },
  "devDependencies": {
    "concurrently": "latest",
    "esbuild": "latest",
    "sass": "latest",
    "typescript": "5.9.*"
  },

  "scripts": {
    "start comments": "concurrently --kill-others \"npm run start:esbuild\" \"npm run start:sass\" \"npm run start:dts\"",
    "start:esbuild": "node ../../../../../../views/goui/esbuild-module.mjs watch",
    "start:sass": "npx sass --load-path=$(npm root) --watch style:dist",
    "start:dts": "npx tsc -b --declaration --emitDeclarationOnly --watch",

    "build": "npm run build:sass && npm run build:ts",
    "build:clean": "rm -rf ./dist/*",
    "build:ts": "node ../../../../../../views/goui/esbuild-module.mjs",
    "build:sass": "npx sass --update --load-path=$(npm root) --style=compressed --no-source-map style:dist",
    "build:dts": "npx tsc -b --declaration --emitDeclarationOnly",

    "test": "npx tsc --noEmit"
  }
}
